# Telegram
TELEGRAM_BOT_TOKEN=
SOURCE_CHANNEL_IDS=-1004445804313,-1004456654534
ADMIN_USER_ID=

# Threads / Meta
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
THREADS_API_BASE=https://graph.threads.net/v1.0

# Crossposting behavior
DATA_DIR=data
MAX_THREAD_CHARS=480
MAX_THREAD_PARTS=5
CROSSPOST_IMAGES=false
CROSSPOST_CASTANEDA_IMMEDIATELY=false
REQUIRE_THREADS_TAG=false
THREADS_TAG=#threads
TELEGRAM_LINK=
ADD_TELEGRAM_LINK_EVERY_N_POSTS=0
THREADS_ENABLED=true


# Bluesky / AT Protocol
BLUESKY_ENABLED=false
BLUESKY_SERVICE=https://bsky.social
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
BLUESKY_MAX_CHARS=280
BLUESKY_MAX_PARTS=8
BLUESKY_IMAGE_ALT=
BLUESKY_MAX_IMAGE_BYTES=2097152
BLUESKY_TAGS=

# Weekly Castaneda post
CASTANEDA_CHANNEL_ID=-1004445804313
CASTANEDA_TELEGRAM_LINK=https://t.me/carlos_castaneda_quotes
WEEKLY_CASTANEDA_ENABLED=false
WEEKLY_CASTANEDA_DAY=thursday
WEEKLY_CASTANEDA_START_TIME=07:07
WEEKLY_CASTANEDA_END_TIME=18:59
TIMEZONE=America/New_York

# Cloudflare R2, needed only when CROSSPOST_IMAGES=true and Telegram images must become public URLs
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_PREFIX=threads_drea_bot/
