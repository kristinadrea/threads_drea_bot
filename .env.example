# Telegram
TELEGRAM_BOT_TOKEN=
SOURCE_CHANNEL_ID=
ADMIN_USER_ID=

# Threads / Meta
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
THREADS_API_BASE=https://graph.threads.net/v1.0

# Crossposting behavior
DATA_DIR=data
MAX_THREAD_CHARS=480
MAX_THREAD_PARTS=5
CROSSPOST_IMAGES=false
REQUIRE_THREADS_TAG=false
THREADS_TAG=#threads
TELEGRAM_LINK=
ADD_TELEGRAM_LINK_EVERY_N_POSTS=0

# Weekly Castaneda post
WEEKLY_CASTANEDA_ENABLED=false
WEEKLY_CASTANEDA_DAY=sunday
WEEKLY_CASTANEDA_TIME=09:00
TIMEZONE=America/New_York
CASTANEDA_QUOTES_FILE=castaneda_quotes.txt
CASTANEDA_MEDIA_URLS_FILE=castaneda_media_urls.txt

# Cloudflare R2, needed only when CROSSPOST_IMAGES=true and Telegram images must become public URLs
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_PREFIX=threads_drea_bot/
